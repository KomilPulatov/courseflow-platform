# Copy to .env and fill in real values for local development.
# Never commit .env. CI and prod use injected secrets.

# --- App ---
APP_ENV=local
APP_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string

# --- Docker host ports ---
# Change these per environment without editing docker-compose.yml.
NGINX_PORT=8081
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
OTEL_GRPC_PORT=4317
OTEL_METRICS_PORT=8889

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crsp
POSTGRES_USER=crsp
POSTGRES_PASSWORD=crsp

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# --- JWT ---
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=60

# --- Observability ---
# Empty endpoint disables OTLP export (keeps a no-op tracer provider).
# In docker-compose, set to: http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_NAME=crsp-backend
OTEL_SERVICE_VERSION=0.1.0
LOG_LEVEL=INFO
SENTRY_DSN=
